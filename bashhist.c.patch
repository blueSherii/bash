 static redisContext *bashhist_redis_ctx = NULL;

+/* Load configuration from YAML file */
+static void
+bashhist_load_config (void)
+{
+  FILE *cf = fopen (CONFIG_FILE, "r");
+  int port = g_redis_port;
+  char hostname[MAXHOSTNAMELEN];
+  char *line = NULL;
+  
+  if (!cf || g_config_loaded)
+    {
+      if (cf) fclose (cf);
+      return;
+    }
+  
+  while ((line = fgets (line, sizeof (line), cf)))
+    {
+      /* Parse hostname: */
+      char *hline = strstr (line, "hostname:");
+      /* Parse redis_port: or port: */
+      char *pline = strstr (line, "redis_port:") ? strstr (line, "redis_port:") : strstr (line, "port:");
+      
+      /* Parse hostname if not set */
+      if (hline && !g_redis_hostname[0])
+        {
+          char *p = hline + strlen ("hostname:");
+          /* Skip any spaces/tabs */
+          while (*p == ' ' || *p == '\t') p++;
+          char *q;
+          q = strchr (p, ':');
+          if (!q) q = strchr (p, '"');
+          if (!q) q = strchr (p, '\'');
+          if (!q) q = strchr (p, '\n');
+          if (q)
+            {
+              *q = '\0';
+              strncpy (g_redis_hostname, p, 255);
+              g_redis_hostname [255] = '\0';
+            }
+        }
+      if (pline)
+        {
+          char start = pline - line + 11;
+          if (start > 0)
+            {
+              char *p = line + start;
+              char *q = strchr (p, ':');
+              char *r = strchr (p, '"');
+              char *s = strchr (p, '\n');
+              char *q_ptr = q ? q : (r ? r : s);
+              if (q_ptr)
+                {
+                  *q_ptr = '\0';
+                  int new_port = atoi (pline);
+                  if (new_port > 0 && new_port < 65536)
+                    port = new_port;
+                }
+            }
+        }
+    }
+  
+  fclose (cf);
+  g_redis_port = port;
+  g_config_loaded = 1;
+}
